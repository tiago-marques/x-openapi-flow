{
  "name": "x-openapi-flow",
  "version": "1.7.1",
  "description": "Enforce, visualize and generate code from OpenAPI resource lifecycles — runtime guard, SDK gen, Postman/Insomnia/Redoc adapters, MCP sidecar for AI agents",
  "main": "lib/validator.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiago-marques/x-openapi-flow.git"
  },
  "homepage": "https://github.com/tiago-marques/x-openapi-flow#readme",
  "bugs": {
    "url": "https://github.com/tiago-marques/x-openapi-flow/issues"
  },
  "files": [
    "bin",
    "lib",
    "adapters",
    "templates",
    "schema",
    "examples",
    "README.md",
    "LICENSE",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "x-openapi-flow": "bin/x-openapi-flow.js",
    "x-openapi-flow-mcp": "bin/x-openapi-flow-mcp.js"
  },
  "scripts": {
    "sync:readme": "node ../scripts/sync-package-readme.js",
    "prepack": "npm run sync:readme",
    "test": "npm run test:cli && npm run test:ui && npm run test:integration && npm run test:runtime && npm run test:engine && npm run test:mcp && npm run test:smoke",
    "test:cli": "node --test tests/cli/cli.test.js",
    "test:ui": "node --test tests/plugins/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:runtime": "node --test tests/runtime/*.test.js",
    "test:engine": "node --test tests/runtime/state-machine-engine.test.js tests/runtime/openapi-state-machine-adapter.test.js",
    "test:examples": "node --test tests/integration/examples.test.js",
    "test:mcp": "node --test tests/cli/mcp.test.js",
    "test:smoke": "node bin/x-openapi-flow.js validate examples/payment-api.yaml --profile strict"
  },
  "keywords": [
    "openapi",
    "oas",
    "openapi-flow",
    "workflow",
    "lifecycle",
    "x-openapi-flow",
    "api-lifecycle",
    "state-machine",
    "openapi-validation",
    "rest-api",
    "workflow-engine",
    "api-governance",
    "postman",
    "insomnia",
    "swagger",
    "redoc",
    "mcp",
    "ai-agent",
    "fastify",
    "express",
    "code-generation",
    "sdk-generator",
    "runtime-guard",
    "api-design",
    "openapi-extension"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0"
  }
}
