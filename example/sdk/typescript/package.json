{
  "name": "x-openapi-flow-example-sdk-typescript",
  "private": true,
  "version": "1.3.1",
  "description": "TypeScript SDK-focused example for x-openapi-flow",
  "scripts": {
    "init": "x-openapi-flow init swagger.json",
    "diff": "x-openapi-flow diff swagger.json --flows examples/swagger.x.yaml --format pretty",
    "apply": "x-openapi-flow apply swagger.json --flows examples/swagger.x.yaml --out swagger.flow.json",
    "validate": "x-openapi-flow validate swagger.flow.json --profile strict",
    "generate": "x-openapi-flow generate-sdk swagger.flow.json --lang typescript --output sdk",
    "build": "tsc -p tsconfig.json",
    "run:sample": "npm run build && node dist/src/sample.js"
  },
  "dependencies": {
    "x-openapi-flow": "file:../../../x-openapi-flow"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
