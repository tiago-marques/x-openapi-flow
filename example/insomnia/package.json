{
  "name": "x-openapi-flow-example-insomnia",
  "private": true,
  "version": "1.3.1",
  "description": "Insomnia-focused example for x-openapi-flow",
  "scripts": {
    "init": "x-openapi-flow init swagger.json",
    "diff": "x-openapi-flow diff swagger.json --flows examples/swagger.x.yaml --format pretty",
    "apply": "x-openapi-flow apply swagger.json --flows examples/swagger.x.yaml --out swagger.flow.json",
    "validate": "x-openapi-flow validate swagger.flow.json --profile strict",
    "generate": "x-openapi-flow generate-insomnia swagger.flow.json --output x-openapi-flow.insomnia.json"
  },
  "dependencies": {
    "x-openapi-flow": "file:../../x-openapi-flow"
  }
}
